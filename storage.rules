rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Imágenes de posts (inline): lectura pública, escritura solo admin.
    match /posts/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email == 'jdinamarca@snakode.com';
    }

    // Cover images: lectura pública, escritura solo admin.
    match /covers/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email == 'jdinamarca@snakode.com';
    }

    // Bloquea todo lo demás por defecto.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
