{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "scanner": {
      "model": "deepseek/deepseek-v4-flash",
      "mode": "subagent",
      "tools": { "write": false, "edit": false, "bash": false }
    },
    "auditor": {
      "model": "zhipuai/glm-5.2",
      "temperature": 0.2,
      "mode": "primary",
      "tools": { "write": false, "edit": false }
    }
  },
  "permission": {
    "bash": {
      "*": "allow",
      "git commit*": "ask",
      "git push*": "ask",
      "git push --force*": "deny",
      "git push -f*": "deny",
      "git reset --hard*": "deny"
    }
  }
}